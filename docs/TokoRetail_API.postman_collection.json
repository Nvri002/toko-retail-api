{
  "info": {
    "name": "TokoRetail API v2 (JWT Auth)",
    "_postman_id": "tokoretail-api-v2",
    "description": "REST API Toko Retail dengan JWT Authentication.\n\n## Alur Penggunaan\n1. Jalankan **[1] Login** → token tersimpan otomatis ke environment\n2. Semua request lain sudah otomatis pakai token tersebut\n3. Jalankan folder secara berurutan dari atas ke bawah\n\n## Default Users\n- **admin** / password123 (role: admin)\n- **staff1** / password123 (role: staff)\n- **staff2** / password123 (role: staff)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 [1] Autentikasi",
      "item": [
        {
          "name": "Login — Dapat Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('success = true', () => pm.expect(pm.response.json().success).to.eql(true));",
            "pm.test('Ada token JWT', () => {",
            "  var d = pm.response.json().data;",
            "  pm.expect(d).to.have.property('token');",
            "  pm.expect(d.token).to.be.a('string').and.not.empty;",
            "  pm.expect(d.token_type).to.eql('Bearer');",
            "  pm.environment.set('token', d.token);",
            "});",
            "pm.test('Info user ada di response', () => {",
            "  var u = pm.response.json().data.user;",
            "  pm.expect(u).to.have.property('id');",
            "  pm.expect(u).to.have.property('username');",
            "  pm.expect(u).to.have.property('role');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "description": "Login dengan username dan password. Token JWT disimpan otomatis ke environment variable 'token'."
          }
        },
        {
          "name": "Login — Username Salah (401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('success = false', () => pm.expect(pm.response.json().success).to.eql(false));",
            "pm.test('Pesan error ada', () => pm.expect(pm.response.json().message).to.include('salah'));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"userTidakAda\",\n  \"password\": \"salah123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login — Password Salah (401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('success = false', () => pm.expect(pm.response.json().success).to.eql(false));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"passwordSalah\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Login — Tanpa Body (400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('success = false', () => pm.expect(pm.response.json().success).to.eql(false));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "GET Me — Info User Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Data user ada', () => {",
            "  var d = pm.response.json().data;",
            "  pm.expect(d).to.have.property('id');",
            "  pm.expect(d).to.have.property('username');",
            "  pm.expect(d).to.have.property('role');",
            "  pm.expect(d).to.not.have.property('password');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "GET Me — Tanpa Token (401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('success = false', () => pm.expect(pm.response.json().success).to.eql(false));",
            "pm.test('Pesan token tidak ditemukan', () => {",
            "  pm.expect(pm.response.json().message.toLowerCase()).to.include('token');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] },
            "description": "Akses tanpa token → harus 401"
          }
        },
        {
          "name": "GET Me — Token Tidak Valid (401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Pesan token tidak valid', () => {",
            "  pm.expect(pm.response.json().message.toLowerCase()).to.include('tidak valid').or.include('invalid');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer tokenpalsu.tidak.valid" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          }
        },
        {
          "name": "POST Register User Baru (Admin Only)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('User terdaftar', () => {",
            "  var d = pm.response.json().data;",
            "  pm.expect(d.username).to.eql('user_baru');",
            "  pm.expect(d).to.not.have.property('password');",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nama\": \"User Baru\",\n  \"username\": \"user_baru\",\n  \"password\": \"password123\",\n  \"role\": \"staff\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "GET Daftar Users (Admin Only)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('data adalah array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
            "pm.test('Password tidak tampil', () => {",
            "  pm.response.json().data.forEach(u => {",
            "    pm.expect(u).to.not.have.property('password');",
            "  });",
            "});"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/users", "host": ["{{base_url}}"], "path": ["api","auth","users"] }
          }
        },
        {
          "name": "PATCH Ganti Password",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('success = true', () => pm.expect(pm.response.json().success).to.eql(true));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"password_lama\": \"password123\",\n  \"password_baru\": \"password123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/change-password", "host": ["{{base_url}}"], "path": ["api","auth","change-password"] },
            "description": "Ganti password lama dan baru (diset sama agar tidak mengganggu test selanjutnya)"
          }
        }
      ]
